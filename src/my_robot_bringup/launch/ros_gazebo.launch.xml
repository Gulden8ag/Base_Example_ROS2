<launch>
    <let name="urdf_path"
         value="$(find-pkg-share my_robot_desc)/urdf/ur_robot.urdf.xacro"/>

    <let name="rviz_config_path"
         value="$(find-pkg-share my_robot_desc)/rviz/UR_new.rviz"/>

    <!-- 
         <arg name="world" default="empty.sdf"/>
    -->

    <node pkg="robot_state_publisher" exec="robot_state_publisher" output="screen">
        <param name="robot_description"
            value="$(command 'xacro $(var urdf_path)')"/>
        <param name="use_sim_time" value="true"/>
        <param name="ignore_timestamp" value="true"/>
    </node>

    <node pkg="inverse_kin" exec="XYZServerGazebo">
        <param name="use_sim_time" value="true"/>
    </node>

    <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
        <arg name="gz_args" value="empty.sdf -r"/>
        <!-- <arg name="gz_args" value="$(var world) -r"/> -->
    </include>

    <node pkg="ros_gz_sim" exec="create" args="-topic robot_description" output="screen"/>


    <!-- Bridge Gazebo clock to ROS2 /clock -->
    <node pkg="ros_gz_bridge" exec="parameter_bridge"
        args="/clock@rosgraph_msgs/msg/Clock[gz.msgs.Clock"
        output="screen"/>


    <!-- These two come after ros2_control is added to the URDF -->
    <node pkg="controller_manager" exec="spawner" args="joint_state_broadcaster" output="screen">
        <param name="use_sim_time" value="true"/>
    </node>
    <node pkg="controller_manager" exec="spawner" args="arm_controller" output="screen">
        <param name="use_sim_time" value="true"/>
    </node>
    <node pkg="rviz2" exec="rviz2" output="screen" args="-d $(var rviz_config_path)">
        <param name="use_sim_time" value="true"/>
    </node>
</launch>